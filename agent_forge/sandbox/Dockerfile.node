FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    curl \
    git \
    jq \
    python3 \
    python3-pip \
    ripgrep \
    tree \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm yarn

WORKDIR /workspace

RUN useradd -m -s /bin/bash agent && chown agent:agent /workspace
USER agent
