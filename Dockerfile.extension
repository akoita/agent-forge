# -----------------------------------------------------------------------
# Dockerfile.extension — build an Agent Forge service image with extensions
#
# Usage:
#   docker build -f Dockerfile.extension \
#     --build-arg EXTENSIONS="agent-forge-proof-of-audit" \
#     -t agent-forge-poa:latest .
#
#   docker build -f Dockerfile.extension \
#     --build-arg EXTENSIONS="agent-forge-proof-of-audit agent-forge-web-security" \
#     -t agent-forge-full:latest .
# -----------------------------------------------------------------------

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

ARG EXTENSIONS=""

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY agent-forge.toml ./agent-forge.toml
COPY agent_forge ./agent_forge
COPY examples ./examples

RUN pip install --no-cache-dir ".[redis]"

# Install extension distributions after the core runtime so their entry points
# are available to the hosted service image. Values are passed directly to
# pip, so published package names and local paths copied into the build context
# (for example ``./examples/my-extension``) are both supported.
RUN if [ -n "${EXTENSIONS}" ]; then \
      pip install --no-cache-dir ${EXTENSIONS}; \
    fi

# Fail the build early when extension metadata or entry points are not
# discoverable inside the image.
RUN agent-forge extensions list

EXPOSE 8000

CMD ["sh", "-lc", "agent-forge serve --host ${AGENT_FORGE_SERVICE_HOST:-0.0.0.0} --port ${AGENT_FORGE_SERVICE_PORT:-8000}"]
